}

float3 FGaussianSplattingInstance::ModelToWorld(in float3 ModelPosition)
{
    return ModelTransform.TransformPosition(ModelPosition);
}

float3 FGaussianSplattingInstance::WorldToModel(in float3 WorldPosition)
{
    return ModelTransform.TransformPositionInverse(WorldPosition);
}

bool FGaussianSplattingInstance::IsShown(in float3 WorldPosition)
{
    FGaussianSplattingVolumes Volumes = Crops;
    while (Volumes < Culls)
    {
        FGaussianSplattingVolume Crop;
        Volumes.Load(Crop);
        float Distance = 1E10f;
        if (!Crop.IsInside(WorldPosition, Distance))
        {
            return false;
        }
    }
    while (Volumes < LocalAppearances)
    {
        FGaussianSplattingVolume Cull;
        Volumes.Load(Cull);
        float Distance = 1E10f;
        if (Cull.IsInside(WorldPosition, Distance))
        {
            return false;
        }
    }
    return true;
}

FGaussianSplattingAppearance FGaussianSplattingInstance::GetAppearance(in float3 WorldPosition)
{
    FGaussianSplattingAppearance A = Appearance;
    FGaussianSplattingVolumes Volumes = LocalAppearances;
    while (Volumes < End)
    {
        FGaussianSplattingVolume Volume;
        Volumes.Load(Volume);
        float Distance = 1E10f;
        if (Volume.IsInside(WorldPosition, Distance))
        {
            float FalloffDistance;
            FGaussianSplattingAppearance LocalAppearance;
            Volumes.PeekAppearance(FalloffDistance, LocalAppearance);
            A.MaxSHDegree = min(A.MaxSHDegree, LocalAppearance.MaxSHDegree);
            if (FalloffDistance + Distance > 0.0f)
            {
                float Weight = -Distance / FalloffDistance;
                // Appearance.MaxSHDegree *= Weight;  // hardly can be useful
                LocalAppearance.HSV.gb *= Weight; // for hue does not make sense, because it results in radial rainbow effect
                LocalAppearance.Tint = lerp(1.0f, LocalAppearance.Tint, Weight);
                LocalAppearance.Gamma = lerp(1.0f, LocalAppearance.Gamma, Weight);
            }
            A.HSV += LocalAppearance.HSV;
            A.Tint *= LocalAppearance.Tint;
            A.Gamma *= LocalAppearance.Gamma;
        }
        Volumes.SkipAppearance();
    }
    return A;
}
