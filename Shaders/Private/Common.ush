uint SortKeyMaskShift;

uint DepthAsSortKey(in float Depth)
{
    uint SortKey = (Depth < 0.0f) ? ~asuint(Depth) : asuint(-Depth);
    return SortKey >> SortKeyMaskShift;
}

float SortKeyAsDepth(in uint SortKey)
{
    SortKey <<= SortKeyMaskShift;
    return (asint(SortKey) < 0) ? -asfloat(SortKey) : asfloat(~SortKey);
}

void GetIndices(
    in uint Index,
    out uint InstanceIndex,
    out uint ModelElementIndex
)
{
    uint Count = InstanceCount;
    InstanceIndex = 0;
    while (Count > 0)  // UpperBound
    {
        uint Step = Count / 2;
        uint Middle = InstanceIndex + Step;
        if (Instances[Middle].BaseIndex <= Index)
        {
            InstanceIndex = Middle + 1;
            Count -= Step + 1;
        }
        else
        {
            Count = Step;
        }
    }
    --InstanceIndex;
    ModelElementIndex = Index - Instances[InstanceIndex].BaseIndex;
}

uint ComposeElementIndex(in uint InstanceIndex, in uint ModelElementIndex)
{
    return InstanceIndex | (ModelElementIndex << InstanceIndexBitCount);
}

void DecomposeElementIndex(uint ElementIndex, out uint InstanceIndex, out uint ModelElementIndex)
{
    InstanceIndex = ElementIndex & InstanceIndexBitmask;
    ModelElementIndex = ElementIndex >> InstanceIndexBitCount;
}

float3 GetTranslation(in float3x4 Transform)
{
    return Transform._m03_m13_m23;
}

float3x3 GetRotationAndScale(in float3x4 Transform)
{
    return (float3x3) Transform;
}

float3 TransformPosition(in float3x4 Transform, in float3 Position)
{
    return mul(GetRotationAndScale(Transform), Position) + GetTranslation(Transform);
}

float3x3 FGaussianSplattingTransform::GetRotation()
{
    return (float3x3) Transform;
}

float3x3 FGaussianSplattingTransform::GetRotationInverse()
{
    return transpose(GetRotation());
}

float3 FGaussianSplattingTransform::GetTranslation()
{
    return Transform._m03_m13_m23;
}

float3 FGaussianSplattingTransform::GetTranslationInverse()
{
    return mul(GetRotationInverse(), GetTranslation()) / -Scale;
}

float3 FGaussianSplattingTransform::TransformPosition(in float3 Position)
{
    return mul(GetRotation(), Position * Scale) + GetTranslation();
}

float3 FGaussianSplattingTransform::TransformPositionInverse(in float3 Position)
{
    return (mul(GetRotationInverse(), Position - GetTranslation())) / Scale;
}

void FGaussianSplattingTransform::AddToTranslation(in float3 Translation)
{
    Transform._m03_m13_m23 += Translation;
}

void FGaussianSplattingTransform::MultiplyBy(in FGaussianSplattingTransform Rhs)
{
    float3x3 RotationTransposed = transpose(mul(Rhs.GetRotation(), GetRotation()));
    float4x3 TransformTransposed =
    {
        RotationTransposed[0],
        RotationTransposed[1],
        RotationTransposed[2],
        Rhs.TransformPosition(GetTranslation()),
    };
    Transform = transpose(TransformTransposed);
    Scale *= Rhs.Scale;
}

void FGaussianSplattingTransform::DivideBy(in FGaussianSplattingTransform Rhs)
{
    float3x3 RotationTransposed = mul(GetRotationInverse(), Rhs.GetRotation());
    float4x3 TransformTransposed =
    {
        RotationTransposed[0],
        RotationTransposed[1],
        RotationTransposed[2],
        Rhs.TransformPositionInverse(GetTranslation()),
    };
    Transform = transpose(TransformTransposed);
    Scale /= Rhs.Scale;
}

void FGaussianSplattingTransform::Invert()
{
    float4x3 TransformTrasposed =
    {
        Transform[0].xyz,
        Transform[1].xyz,
        Transform[2].xyz,
        GetTranslationInverse(),
    };
    Transform = transpose(TransformTrasposed);
    Scale = 1.0f / Scale;
}

struct FPlane
{
    float3 Normal;
    float Distance;

    float GetDistance(float3 Point)
    {
        return dot(Normal, Point) - Distance;
    }
};

void FGaussianSplattingVolumes::Load(out int Value)
{
    Value = Volumes.Load<int>(Offset);
    Offset += 4;
}

void FGaussianSplattingVolumes::Load(out float4 Value)
{
    Value = Volumes.Load<float4>(Offset);
    Offset += 16;
}

void FGaussianSplattingVolumes::Load(out FGaussianSplattingVolume Volume)
{
    int Size = Volumes.Load<int>(Offset);
    Volume.Box = Volumes.Load<float3x4>(Offset + 4);
    Volume.Origin = Volumes.Load<float3>(Offset + 52);
    Volume.BoxExtent = Volumes.Load<float3>(Offset + 64);
    Volume.SphereRadius = Volumes.Load<float>(Offset + 76);
    Volume.ConvexElems.Offset = Offset + 80;
    Offset += Size;
}

void FGaussianSplattingVolumes::Load(out FPlane Plane)
{
    Plane.Normal = Volumes.Load<float3>(Offset);
    Plane.Distance = Volumes.Load<float>(Offset + 12);
    Offset += 16;
}

void FGaussianSplattingVolumes::PeekAppearance(out float FalloffDistance, out FGaussianSplattingAppearance Appearance)
{
    FalloffDistance = Volumes.Load<float>(Offset);
    Appearance.MaxSHDegree = Volumes.Load<int>(Offset + 4);
    Appearance.HSV = Volumes.Load<float3>(Offset + 8);
    Appearance.Tint = Volumes.Load<float3>(Offset + 20);
    Appearance.Gamma = Volumes.Load<float>(Offset + 32);
}

void FGaussianSplattingVolumes::SkipAppearance()
{
    Offset += 36;
}

bool FGaussianSplattingVolume::IsInside(in float3 WorldPosition, inout float Distance)
{
    float3 ModelPosition = TransformPosition(Box, WorldPosition);
    if (distance(Origin, ModelPosition) > SphereRadius)
    {
        return false;
    }
    int ConvexElemsNum;
    ConvexElems.Load(ConvexElemsNum);
    for (int ConvexElemIndex = 0; ConvexElemIndex < ConvexElemsNum; ++ConvexElemIndex)
    {
        int PlanesNum;
        ConvexElems.Load(PlanesNum);
        FPlane Plane;
        float ConvexElemDistance = -1E10;
        for (int PlaneIndex = 0; PlaneIndex < PlanesNum; ++PlaneIndex)
        {
            ConvexElems.Load(Plane);
            float PlaneDistance = Plane.GetDistance(ModelPosition);
            ConvexElemDistance = max(ConvexElemDistance, PlaneDistance);
        }
        Distance = min(Distance, ConvexElemDistance);
        if (ConvexElemDistance <= 0.0f)
        {
            return true;  // early exit is correct because ConvexElems are disjoint
        }
    }
    return false;
}

FGaussianSplat FGaussianSplattingInstance::GetGaussianSplat(in uint ModelElementIndex)
{
    switch (BaseModelIndex + ModelElementIndex / CHUNK_LEN)
    {
        default:
            return Models_0[ModelElementIndex % CHUNK_LEN];
#define CASE(N) \
        case N: \
            return Models_##N[ModelElementIndex % CHUNK_LEN];
