#pragma once

#include "/Engine/Public/Platform.ush"

#ifndef MAX_SH_ORDER
#define MAX_SH_ORDER 4
#endif

#ifndef CHUNK_LEN
#define CHUNK_LEN 8012998
#endif

struct FGaussianSplattingVolume;
struct FPlane;
struct FGaussianSplattingAppearance;

struct FGaussianSplattingVolumes
{
    int Offset;

    void Load(out int Value);
    void Load(out float4 Value);
    void Load(out FGaussianSplattingVolume Volume);
    void Load(out FPlane Plane);

    void PeekAppearance(out float FalloffDistance, out FGaussianSplattingAppearance Appearance);
    void SkipAppearance();

    bool operator<(int End)
    {
        return Offset < End;
    }

    bool operator<(in FGaussianSplattingVolumes Volumes)
    {
        return this < Volumes.Offset;
    }
};

struct FGaussianSplattingTransform
{
    float3x4 Transform;  // Rotation * Translation
    float3 Scale;

    float3x3 GetRotation();
    float3x3 GetRotationInverse();
    float3 GetTranslation();
    float3 GetTranslationInverse();

    float3 TransformPosition(in float3 Position);
    float3 TransformPositionInverse(in float3 Position);

    void AddToTranslation(in float3 Translation);
    void MultiplyBy(in FGaussianSplattingTransform Rhs);
    void DivideBy(in FGaussianSplattingTransform Rhs);

    void Invert();

};

struct FGaussianSplat
{
    FGaussianSplattingTransform Transform;
    float3 Normal;
    float4 Albedo;
#if MAX_SH_ORDER > 1
    float3 SH[MAX_SH_ORDER * MAX_SH_ORDER - 1];
#endif
};

struct FGaussianSplattingVolume
{
    float3x4 Box;
    float3 Origin;
    float3 BoxExtent;
    float SphereRadius;
    FGaussianSplattingVolumes ConvexElems;

    bool IsInside(in float3 WorldPosition, inout float Distance);
};

struct FGaussianSplattingAppearance
{
    int MaxSHDegree;
    float3 HSV;
    float3 Tint;
    float Gamma;
};

struct FGaussianSplattingInstance
{
    uint Flags;
    uint BaseModelIndex;
    uint BaseIndex;
    FGaussianSplattingTransform ModelTransform;
    float Scale;
    float MaxLambda;
    FGaussianSplattingAppearance Appearance;

    FGaussianSplattingVolumes Crops;
    FGaussianSplattingVolumes Culls;
    FGaussianSplattingVolumes LocalAppearances;
    int End;

    FGaussianSplat GetGaussianSplat(in uint ModelElementIndex);
    float3 ModelToWorld(in float3 ModelPosition);
    float3 WorldToModel(in float3 WorldPosition);
    bool IsShown(in float3 WorldPosition);
    FGaussianSplattingAppearance GetAppearance(in float3 WorldPosition);
};

